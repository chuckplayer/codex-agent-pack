{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'pack=\"${CODEX_AGENT_PACK_HOME:-${CODEX_HOME:-$HOME/.codex}/agent-pack}\"; hook=\"$pack/hooks/codex-user-prompt-hook.sh\"; if [ -f \"$hook\" ]; then bash \"$hook\"; fi'",
            "commandWindows": "\"C:\\Program Files\\Git\\usr\\bin\\bash.exe\" -lc 'pack=\"${CODEX_AGENT_PACK_HOME:-${CODEX_HOME:-$HOME/.codex}/agent-pack}\"; hook=\"$pack/hooks/codex-user-prompt-hook.sh\"; if [ -f \"$hook\" ]; then bash \"$hook\"; fi'",
            "timeout": 10,
            "statusMessage": "Recording Codex prompt context"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -c 'pack=\"${CODEX_AGENT_PACK_HOME:-${CODEX_HOME:-$HOME/.codex}/agent-pack}\"; hook=\"$pack/hooks/codex-stop-hook.sh\"; if [ -f \"$hook\" ]; then bash \"$hook\"; fi'",
            "commandWindows": "\"C:\\Program Files\\Git\\usr\\bin\\bash.exe\" -lc 'pack=\"${CODEX_AGENT_PACK_HOME:-${CODEX_HOME:-$HOME/.codex}/agent-pack}\"; hook=\"$pack/hooks/codex-stop-hook.sh\"; if [ -f \"$hook\" ]; then bash \"$hook\"; fi'",
            "timeout": 30,
            "statusMessage": "Recording Codex session update"
          }
        ]
      }
    ]
  }
}
